{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/rocm-agent-corpus/profile.schema.json",
  "title": "HIP/ROCm Agent Corpus Profile Summary",
  "type": "object",
  "required": ["schema_version", "task_id", "artifact", "tool", "hardware", "metrics"],
  "properties": {
    "schema_version": { "type": "string" },
    "task_id": { "type": "string" },
    "artifact": { "type": "string" },
    "tool": {
      "type": "object",
      "required": ["name", "version", "command"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "command": { "type": "string" }
      },
      "additionalProperties": false
    },
    "hardware": { "type": "string" },
    "metrics": { "type": "object" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}

