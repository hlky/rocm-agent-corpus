          "causal": false
        }
      ],
      "dtypes": [
        "fp32-seed",
        "fp16-future",
        "bf16-future",
        "fp8-future"
      ],
      "layouts": [
        "contiguous B,H,S,D",
        "BSHD future",
        "paged-kv-cache future",
        "grouped-query future"
      ],
      "baselines": [
        "host-reference",
        "custom-naive",
        "custom-online-tiled",
        "flash-attention",
        "miopen-frontend",
        "triton",
        "vllm-rocm",
        "vllm",
        "flashinfer"
      ],
      "custom_candidates": [
        "one CTA per query row online softmax",
        "warp-specialized decode for query_length=1",
        "Matrix Core QK and PV tiles",
        "double-buffered K/V shared-memory tiles",
        "causal tile skipping",
        "fixed-shape head_dim specialization",
        "paged-KV layout specialization",
        "fused rotary or bias before QK"
      ],
      "win_hypotheses": [
        "The online custom seed should reduce memory traffic versus materializing scores and probabilities.",
        "A narrow decode kernel can win when query_length=1, head_dim and KV layout are fixed, and serving libraries carry more general batching or paging support than the workload needs.",
        "A custom fused variant can win when scale, mask, rotary, bias, or output transform would otherwise require extra launches or memory passes."
      ],
      "negative_examples_to_keep": [
        "The online seed loses because scalar dot products do not use Matrix Cores.",
        "A larger key tile loses due to shared-memory pressure or lower occupancy.",
        "A decode-specialized kernel wins isolated timing but loses end-to-end serving latency once KV-cache layout and scheduler costs are included.",
        "A custom prefill kernel loses to FlashAttention because its mainloop lacks global-to-LDS staging, MFMA, or better work partitioning."
      ]
    }
  ]
}
