        "fp32-scale",
        "uint4-zero-point",
        "fp32-activation",
        "fp32-accumulate",
        "fp32-output"
      ],
      "layouts": [
        "row-major packed weights",
        "even K in low nibble",
        "odd K in high nibble",
        "per-row per-group scale",
        "per-row per-group zero point"
      ],
      "baselines": [
        "host-reference",
        "materialized-dequant",
        "custom-naive-fused",
        "custom-cooperative-fused",
        "bitsandbytes",
        "composable-kernel",
        "hipblaslt",
        "vllm-rocm",
        "triton",
        "framework-generated"
      ],
      "custom_candidates": [
        "one-thread-per-row fused kernel",
        "one-CTA-per-row fused reduction",
        "one-warp-per-row fused reduction",
        "vectorized packed-byte or packed-word loads",
        "scale reuse across group-size chunks",
        "fused bias or activation",
        "half or bfloat16 output path"
      ],
      "win_hypotheses": [
        "Fusing dequantization into GEMV avoids materialized FP16 or FP32 weights and reduces memory traffic.",
        "Known group size and packing order remove generic quantization branches.",
        "Decode-like GEMV shapes can reward one-row cooperative scheduling over generic GEMM machinery.",
        "Fusing bias, activation, or output quantization can remove extra launches and memory passes."
      ],
      "negative_examples_to_keep": [
        "Unpacking and scale loads dominate for small K or tiny rows.",
        "One CTA per row underutilizes the GPU for too few rows.",
        "Shared-memory reduction loses to warp-level reduction because synchronization overhead is too high.",
        "Custom kernel beats materialized dequant but loses to a matching vLLM on ROCm, Composable Kernel, or bitsandbytes path.",
        "Numerical mismatch from zero-point layout or nibble order invalidates a speed result."
      ]
    },
