  "tasks": [
    {
      "id": "fused-int4-dequant-gemv",
      "status": "timing-only-measured",
      "path": "corpus/tasks/fused-int4-dequant-gemv/task.json",
      "objective": "Teach packed int4 weight-only GEMV with per-row/per-group scale and zero-point metadata, fusing unpack, dequantization, multiply, and reduction.",
      "shape_families": [
        "decode-gemv",
        "weight-only-linear",
