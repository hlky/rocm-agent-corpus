{
  "schema_version": "0.1.0",
  "track_id": "quantization-kernel-track",
  "guide": "docs/QUANTIZATION_KERNEL_GUIDE.md",
  "mission": "Teach agents to write, measure, and explain custom quantization and fused dequantization kernels that beat, match, specialize beyond, or extend bitsandbytes, Transformer Engine on ROCm, Composable Kernel, hipBLASLt, MIGraphX, vLLM on ROCm, Triton, vLLM, FlashInfer, and framework-generated baselines for scoped workloads.",
  "evidence_policy": {
    "default_unmeasured_status": "template-only",
    "default_profiler_status": "timing-only",
    "required_result_classes": [
      "custom-win",
      "custom-specialized-win",
      "near-match",
      "library-win",
      "negative-example",
      "correctness-fail",
      "compile-fail",
      "template-only"
    ],
    "must_not_claim": [
      "rocprofiler/rocprof counters unless collected",
      "fair low-bit library comparison unless scale, zero-point, packing, accumulator, output dtype, and epilogue contracts match",
      "custom win over vLLM on ROCm or Composable Kernel unless their closest matching quantized path was configured and measured",
      "packed-load efficiency without profiling or a timing-backed comparison",
      "FP8 or NVFP4 numerical equivalence unless format, scale, saturation, and amax policy are recorded"
    ]
  },
  "metadata_requirements": [
    "task_id",
    "result_class",
    "gpu_name",
    "gfx_target",
    "driver_version",
    "rocm_version",
    "compiler_version",
    "build_command",
    "arch_flags",
    "operation",
    "m",
    "n",
    "k",
    "batch_count",
    "rows",
    "cols",
    "head_dim",
    "dtype_quantized",
    "dtype_scale",
    "dtype_accumulator",
    "dtype_output",
    "quant_format",
    "packing_order",
    "group_size",
    "scale_layout",
    "zero_point_layout",
    "activation_scale_layout",
    "epilogue",
    "alignment_bytes",
    "packed_load_width",
    "warmup_iterations",
    "measured_iterations",
    "timer_type",
    "profiler_status",
    "correctness_reference",
    "tolerance",
    "seed",
    "baseline_versions",
    "win_loss_notes"
  ],
  "baseline_definitions": [
