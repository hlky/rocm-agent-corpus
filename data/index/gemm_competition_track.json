{
  "schema_version": "0.1.0",
  "track_id": "gemm-competition",
  "guide": "docs/GEMM_COMPETITION_TRACK.md",
  "mission": "Teach agents to write, measure, and explain custom GEMM kernels that beat, match, specialize beyond, or extend hipBLAS/rocBLAS, hipBLASLt, Composable Kernel, Triton, MIGraphX, and framework-generated baselines for scoped workloads.",
  "evidence_policy": {
    "default_profiler_status": "timing-only",
    "required_result_classes": [
      "custom-win",
      "custom-specialized-win",
      "near-match",
      "library-win",
      "negative-example",
      "correctness-fail",
      "compile-fail"
    ],
    "must_not_claim": [
      "rocprofiler/rocprof counters unless collected",
      "fair hipBLASLt comparison unless algorithm search and workspace are recorded",
      "fair TF32 comparison unless math mode is explicit",
      "epilogue win unless library epilogue baseline is considered where supported"
    ]
  },
  "examples": [
    {
      "path": "examples/gemm/README.md",
      "role": "local track entrypoint"
    },
    {
      "path": "examples/gemm/fixed_shape_sgemm_skeleton.hip",
      "role": "small fixed-shape custom GEMM skeleton"
    },
    {
      "path": "examples/gemm/hipblaslt_baseline_skeleton.hip",
      "role": "hipBLASLt baseline and metadata skeleton"
    }
  ],
  "metadata_requirements": [
    "task_id",
    "result_class",
    "gpu_name",
    "gfx_target",
    "driver_version",
    "rocm_version",
    "compiler_version",
    "build_command",
    "arch_flags",
    "m",
    "n",
    "k",
    "batch_count",
    "group_count",
    "layout_a",
    "layout_b",
    "layout_c",
    "layout_d",
    "lda",
    "ldb",
    "ldc",
    "ldd",
    "dtype_a",
    "dtype_b",
    "dtype_accumulator",
    "dtype_output",
    "math_mode",
    "alpha",
    "beta",
    "epilogue",
    "alignment_bytes",
    "workspace_bytes",
    "warmup_iterations",
    "measured_iterations",
    "timer_type",
    "profiler_status",
    "correctness_reference",
    "tolerance",
    "seed",
    "baseline_versions",
    "win_loss_notes"
  ],
  "baseline_definitions": [
    {
      "id": "host-reference",
      "kind": "correctness-oracle",
      "records": [
        "accumulator semantics",
        "rounding and cast policy",
        "epilogue semantics"
      ]
    },
    {
      "id": "custom-naive",
      "kind": "educational-custom",
      "records": [
        "indexing",
        "layout mapping",
        "alpha_beta_contract"
      ]
    },
    {
      "id": "custom-shared-memory",
      "kind": "custom-baseline",
      "records": [
        "cta_tile",
        "thread_tile",
        "shared_memory_bytes",
        "edge_handling"
      ]
    },
    {
      "id": "custom-tensor-core",
      "kind": "custom-advanced",
      "records": [
        "mma_instruction_or_rocwmma_shape",
        "accumulator_type",
        "pipeline_stages",
        "architecture_path"
      ]
    },
    {
      "id": "hipblas",
      "kind": "vendor-competitor",
      "records": [
        "api_call",
        "transpose_flags",
        "leading_dimensions",
        "math_mode",
        "tf32_policy"
      ]
    },
    {
      "id": "hipblaslt",
      "kind": "vendor-competitor-and-epilogue-reference",
      "records": [
        "matmul_desc",
        "matrix_layouts",
        "preference_workspace",
        "heuristic_count",
        "selected_algorithm",
        "epilogue_attributes"
      ]
    },
    {
      "id": "composable-kernel",
      "kind": "competitor-and-extension-surface",
      "records": [
        "composable-kernel_commit",
        "example_ancestor",
        "cta_tile",
        "warp_tile",
        "instruction_tile",
        "stages",
        "scheduler",
        "epilogue_operator"
      ]
    },
    {
      "id": "triton",
      "kind": "compiler-competitor",
      "records": [
        "meta_parameters",
        "compile_boundary",
        "framework_version",
        "dispatch_included"
      ]
    }
  ],
  "tasks": [
    {
      "id": "sgemm-naive-shared",
      "status": "planned",
      "objective": "Teach FP32 GEMM indexing, coalescing, and shared-memory tiling before comparing against vendor baselines.",
      "shape_families": [
        "medium-square",
        "rectangular"
      ],
      "candidate_shapes": [
        {
          "m": 128,
          "n": 128,
          "k": 128
        },
        {
          "m": 512,
          "n": 512,
          "k": 512
        },
        {
          "m": 1024,
          "n": 256,
          "k": 768
        }
      ],
      "dtypes": [
        "fp32"
      ],
      "layouts": [
        "row-major contiguous",
        "column-major library mapping"
      ],
      "baselines": [
        "host-reference",
        "custom-naive",
        "custom-shared-memory",
        "hipblas",
        "hipblaslt"
      ],
      "custom_candidates": [
        "one-output-element-per-thread",
        "16x16 shared-memory tile",
        "32x32 shared-memory tile",
        "register tiling"
      ],
      "win_hypotheses": [
        "Shared-memory custom kernel should beat naive by reducing global loads.",
        "hipBLAS/rocBLAS/hipBLASLt should usually beat educational FP32 custom kernels unless shape specialization or fusion is added."
      ],
      "negative_examples_to_keep": [
        "Shared-memory tile slower than hipBLAS/rocBLAS because Matrix Core or TF32 math mode was enabled in the library.",
        "Larger tile loses due to register pressure or low occupancy."
      ]
    },
