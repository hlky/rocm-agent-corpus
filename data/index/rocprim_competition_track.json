    {
      "id": "cccl-fused-transform-reduce",
      "priority": "p0",
      "category": "reduction",
      "status": "template-only",
      "baseline_apis": [
        "hipcub::DeviceReduce::TransformReduce",
        "hipcub::DeviceReduce::Reduce with transform iterator",
        "rocthrust::transform_reduce"
      ],
      "custom_strategy": "Fuse the transform, local accumulation, block reduction, and final write or atomic into a single workload-specific kernel.",
      "discarded_generality": [
        "single dtype and accumulator",
        "known transform",
        "known alignment",
        "fixed item count family",
        "no arbitrary binary operator dispatch"
      ],
      "candidate_shapes": [
        "n=1048576 float32 contiguous",
        "n=16777216 float32 contiguous",
        "rows=4096 cols=256 rowwise statistics"
      ],
      "correctness_oracles": [
        "hipCUB TransformReduce output",
        "CPU double-precision reference for tolerance checks"
      ],
      "artifacts_to_capture": [
        "hipCUB temp_storage_bytes",
        "baseline launch count",
        "custom launch count",
        "allocation timed or excluded",
        "accumulator dtype",
        "evidence label"
      ],
      "negative_examples": [
        "generic two-pass custom reduction slower than hipCUB",
        "vectorized load variant slower due to register pressure or alignment guards"
      ],
      "example_files": [
        "examples/rocprim/fused_transform_reduce_competitor.hip"
      ]
    },
