  "cross_cutting_negative_examples": [
    {
      "id": "cccl-negative-generic-shuffle-reduction",
      "lesson": "A generic shuffle tree is often slower and less correct than hipCUB BlockReduce or DeviceReduce unless the task has fixed shape or fusion value.",
      "expected_label": "timing-only-measured-negative"
    },
    {
      "id": "cccl-negative-atomic-histogram-hot-bins",
      "lesson": "Direct global atomics can look acceptable on uniform data and collapse on skewed distributions.",
      "expected_label": "timing-only-measured-negative"
    },
    {
      "id": "cccl-negative-vectorized-reduce",
      "lesson": "Vectorized loads can lose when alignment checks, tails, or register pressure exceed memory-transaction savings.",
      "expected_label": "timing-only-measured-negative"
    },
    {
      "id": "cccl-negative-topk-sorted-contract",
      "lesson": "Sorting a custom top-k result can erase wins when the downstream operation accepts unsorted candidates.",
